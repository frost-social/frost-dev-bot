{
  "tasks": {
    "dev": "deno serve --watch -R main.ts",
    "test":"deno test --allow-read=. --allow-env",
    "deploy": "deno run --allow-read=. --allow-env --allow-run scripts/deploy.ts",
    "deploy-prod": "deno run --allow-read=. --allow-env --allow-run scripts/deploy.ts --prod"
  },
  "imports": {
    "@octokit/webhooks": "npm:@octokit/webhooks@^13.8.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.3",
    "@std/http": "jsr:@std/http@1"
  },
  "deploy": {
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "src/main.ts"
  }
}
